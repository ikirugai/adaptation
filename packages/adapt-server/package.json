{
  "name": "@ikirugai/adapt-server",
  "version": "0.1.2",
  "description": "Server-side primitives for Adaptation — defineSurface, session helpers, route-handler factories, DSL, generic patch applier.",
  "license": "MIT",
  "author": "Ikirugai",
  "homepage": "https://adapt.ikirugai.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ikirugai/adaptation.git",
    "directory": "packages/adapt-server"
  },
  "bugs": "https://github.com/ikirugai/adaptation/issues",
  "keywords": [
    "next",
    "next.js",
    "ai",
    "anthropic",
    "claude",
    "adaptive",
    "personalisation",
    "feature-flags",
    "server-actions"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./handlers": {
      "types": "./dist/handlers.d.ts",
      "import": "./dist/handlers.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && node scripts/add-js-extensions.mjs",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "pg": "^8.13.1"
  },
  "peerDependencies": {
    "next": ">=15",
    "react": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.12",
    "next": "^15.5.18",
    "react": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
